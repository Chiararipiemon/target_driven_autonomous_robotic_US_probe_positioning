<?xml version="1.0"?>
<!--
  Description
  Starts the CSV pose logger node. The node logs TF poses (fixed_frame -> ee_frame)
  to a CSV file when the ~start service is called, and stops on ~stop.

  Usage
    roslaunch iiwa_probe_utils csv_logger.launch
    rosservice call /csv_logger/start
    rosservice call /csv_logger/stop

  What to change for your own setup
  - Set fixed_frame and ee_frame to match your TF tree.
  - Use units:=m if you want positions in meters.
  - Change output_dir/prefix to organize datasets.
  - Use tip_offset_m if you want to log an offset point instead of the frame origin.
-->

<launch>
  <arg name="fixed_frame" default="world"/>
  <arg name="ee_frame" default="probe_tip"/>
  <arg name="units" default="mm"/>
  <arg name="rate_hz" default="20"/>
  <arg name="output_dir" default="$(env HOME)/iiwa_csv"/>
  <arg name="tip_offset_m" default="0.0"/>
  <arg name="prefix" default="us_poses"/>
  <arg name="flush_every_n" default="1"/>

  <node pkg="iiwa_probe_utils" type="csv_logger.py" name="csv_logger" output="screen">
    <param name="fixed_frame" value="$(arg fixed_frame)"/>
    <param name="ee_frame" value="$(arg ee_frame)"/>
    <param name="units" value="$(arg units)"/>
    <param name="rate_hz" value="$(arg rate_hz)"/>
    <param name="output_dir" value="$(arg output_dir)"/>
    <param name="tip_offset_m" value="$(arg tip_offset_m)"/>
    <param name="prefix" value="$(arg prefix)"/>
    <param name="flush_every_n" value="$(arg flush_every_n)"/>
  </node>
</launch>
