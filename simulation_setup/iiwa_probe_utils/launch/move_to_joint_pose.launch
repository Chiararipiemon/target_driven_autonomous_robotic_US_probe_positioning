<?xml version="1.0"?>
<launch>
  <group ns="iiwa">
    <node pkg="iiwa_probe_utils" type="move_to_joint_pose.py" name="move_to_joint_pose" output="screen">
      <param name="group_name" value="manipulator"/>
      <param name="eef_link" value="tool0"/>
      <param name="reference_frame" value="world"/>
      <param name="planner_id" value="RRTConnectkConfigDefault"/>
      <param name="planning_pipeline_id" value="ompl"/>
      <param name="num_attempts" value="20"/>
      <param name="planning_time" value="20.0"/>
      <param name="vel_scale" value="0.1"/>
      <param name="acc_scale" value="0.1"/>
      <param name="iiwa_joint_1" value="-0.728"/>
      <param name="iiwa_joint_2" value="0.048"/>
      <param name="iiwa_joint_3" value="0.949"/>
      <param name="iiwa_joint_4" value="-0.595"/>
      <param name="iiwa_joint_5" value="-0.193"/>
      <param name="iiwa_joint_6" value="1.670"/>
      <param name="iiwa_joint_7" value="0.097"/>
    </node>
  </group>
</launch>
